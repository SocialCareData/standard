{
  "@context": {
    "pl":  "https://ns.socialcaredata.io/placements/",
    "cln": "https://ns.socialcaredata.io/placements/cultural-need#",
    "cn":  "https://ns.socialcaredata.io/placements/communication-need#",
    "la":  "https://ns.socialcaredata.io/placements/living-arrangement#",
    "pa":  "https://ns.socialcaredata.io/placements/pets-allowance#",
    "pt":  "https://ns.socialcaredata.io/placements/placement-type#",
    "pu":  "https://ns.socialcaredata.io/placements/placement-urgency#",
    "rl":  "https://ns.socialcaredata.io/placements/risk-level#",
    "sl":  "https://ns.socialcaredata.io/placements/suitability-level#",
    "st":  "https://ns.socialcaredata.io/placements/support-type#",
    "yns": "https://ns.socialcaredata.io/placements/presence-status#",
    "olr": "https://ns.socialcaredata.io/placements/outof-la-reason#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ex":  "https://example.org/placement/",

    "Placement":                 "pl:Placement",
    "PlacementAvailability":     "pl:PlacementAvailability",
    "PlacementRequirements":     "pl:PlacementRequirements",
    "PlacementRecommendation":   "pl:PlacementRecommendation",
    "RiskAssessment":            "pl:RiskAssessment",
    "ActualPlacement":           "pl:ActualPlacement",
    "QualityAssurance":          "pl:QualityAssurance",

    "childId":                       "pl:childId",
    "hasPlacementAvailability":      { "@id": "pl:hasPlacementAvailability",      "@type": "@id" },
    "hasPlacementRequirements":      { "@id": "pl:hasPlacementRequirements",      "@type": "@id" },
    "hasPlacementRecommendation":    { "@id": "pl:hasPlacementRecommendation",    "@type": "@id" },
    "hasRiskAssessment":             { "@id": "pl:hasRiskAssessment",             "@type": "@id" },
    "hasActualPlacement":            { "@id": "pl:hasActualPlacement",            "@type": "@id" },
    "hasQualityAssurance":           { "@id": "pl:hasQualityAssurance",           "@type": "@id" },

    "placementId":          "pl:placementId",
    "neededBy":             { "@id": "pl:neededBy",             "@type": "@vocab", "@context": {
      "@vocab": "https://ns.socialcaredata.io/placements/placement-urgency#",
      "< 5 days": "pu:WithinFiveDays",
      "> 5 days": "pu:MoreThanFiveDays"
    } },
    "siblingCount":         { "@id": "pl:siblingCount",         "@type": "xsd:nonNegativeInteger" },
    "isPreferredLocationLocal":    "pl:isPreferredLocationLocal",
    "outOfLAReason":        { "@id": "pl:outOfLAReason",      "@type": "@id", "@context": {
      "SafeguardingConcerns": "olr:SafeguardingConcerns",
      "Safeguarding concerns": "olr:SafeguardingConcerns",
      "BailConditions": "olr:BailConditions",
      "Bail conditions": "olr:BailConditions",
      "CourtOrder": "olr:CourtOrder",
      "Court order": "olr:CourtOrder",
      "OutOfLAReasonOther": "olr:OutOfLAReasonOther",
      "Other": "olr:OutOfLAReasonOther"
    } },
    "outOfLAReasonOther":   { "@id": "pl:outOfLAReasonOther", "@container": "@set" },

    "communicationNeeds":               { "@id": "pl:communicationNeeds",               "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/presence-status#", "Not Specified": "yns:NotSpecified" } },
    "specificCommunicationRequirement": { "@id": "pl:specificCommunicationRequirement", "@type": "@vocab", "@container": "@set", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/communication-need#" } },
    "culturalNeeds":                    { "@id": "pl:culturalNeeds",                    "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/cultural-need#", "Not Required": "cln:NotRequired", "Not Known": "cln:NotKnown" } },
    "livingCompanions":                 { "@id": "pl:livingCompanions",                 "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/living-arrangement#", "Solo placement recommended": "la:SoloPlacement", "With Other children recommended": "la:WithOtherChildren", "Only With Other older children": "la:OnlyWithOlderChildren", "Only With Other younger children": "la:OnlyWithYoungerChildren", "No preference": "la:NoPreference" } },
    "pets":                             { "@id": "pl:pets",                             "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/pets-allowance#", "Yes-must": "pa:YesMust", "Yes-can": "pa:YesCan", "Not known": "pa:NotKnown" } },
    "additionalSupport":                { "@id": "pl:additionalSupport",                "@type": "@vocab", "@container": "@set", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/support-type#", "Additional supervision": "st:AdditionalSupervision", "Therapeutic support": "st:TherapeuticSupport", "A worker for respite": "st:WorkerForRespite", "Taxis to school": "st:TaxisToSchool", "NA": "st:NotApplicable" } },
    "additionalSupportOther":           { "@id": "pl:additionalSupportOther",           "@container": "@set" },
    "culturalNeedsOther":               { "@id": "pl:culturalNeedsOther",               "@container": "@set" },
    "specificCommunicationRequirementOther": { "@id": "pl:specificCommunicationRequirementOther", "@container": "@set" },
    "homeAdaptationRequired":           "pl:homeAdaptationRequired",
    "deprivationOfLiberty":             "pl:deprivationOfLiberty",

    "fosterCareSuitability":            { "@id": "pl:fosterCareSuitability",            "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/suitability-level#", "Suitable but not preferred": "sl:SuitableButNotPreferred", "Not specified": "sl:NotSpecified" } },
    "residentialCareSuitability":       { "@id": "pl:residentialCareSuitability",       "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/suitability-level#", "Suitable but not preferred": "sl:SuitableButNotPreferred", "Not specified": "sl:NotSpecified" } },
    "supportedAccommodationSuitability":{ "@id": "pl:supportedAccommodationSuitability","@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/suitability-level#", "Suitable but not preferred": "sl:SuitableButNotPreferred", "Not specified": "sl:NotSpecified" } },

    "riskSelfHarm":              { "@id": "pl:riskSelfHarm",              "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskCriminalExploitation":  { "@id": "pl:riskCriminalExploitation",  "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskDrugAlcohol":           { "@id": "pl:riskDrugAlcohol",           "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskEatingDisorder":        { "@id": "pl:riskEatingDisorder",        "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskMissing":               { "@id": "pl:riskMissing",               "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskSexualExploitation":    { "@id": "pl:riskSexualExploitation",    "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskToOthersPhysical":      { "@id": "pl:riskToOthersPhysical",      "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskToOthersSexual":        { "@id": "pl:riskToOthersSexual",        "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskToOthersFire":          { "@id": "pl:riskToOthersFire",          "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskToOthersAnimals":       { "@id": "pl:riskToOthersAnimals",       "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskToOthersCriminal":      { "@id": "pl:riskToOthersCriminal",      "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/risk-level#", "Risk Present": "rl:RiskPresent", "No known risk": "rl:NoKnownRisk" } },
    "riskOther":                 { "@id": "pl:riskOther",         "@container": "@set" },
    "riskToOthersOther":         { "@id": "pl:riskToOthersOther", "@container": "@set" },

    "placementType":           { "@id": "pl:placementType", "@type": "@vocab", "@context": { "@vocab": "https://ns.socialcaredata.io/placements/placement-type#", "Supported Accommodation": "pt:SupportedAccommodation" } },
    "providerURN":             "pl:providerURN",
    "placementLocation":       "pl:placementLocation",
    "isLocationPreferred":     "pl:isLocationPreferred",
    "isEducationContinuous":   "pl:isEducationContinuous",
    "siblingsPlacedTogether":  { "@id": "pl:siblingsPlacedTogether", "@type": "xsd:nonNegativeInteger" },
    "totalWeeklyCost":         { "@id": "pl:totalWeeklyCost",        "@type": "xsd:decimal" },
    "coreWeeklyCost":              { "@id": "pl:coreWeeklyCost",              "@type": "xsd:decimal" },
    "additionalSupportWeeklyCost": { "@id": "pl:additionalSupportWeeklyCost", "@type": "xsd:decimal" },
    "educationWeeklyCost":         { "@id": "pl:educationWeeklyCost",         "@type": "xsd:decimal" },
    "otherWeeklyCost":             { "@id": "pl:otherWeeklyCost",             "@type": "xsd:decimal" },

    "referralDate":          { "@id": "pl:referralDate",     "@type": "xsd:date" },
    "referralOfficerName":   "pl:referralOfficerName",
    "placementDate":         { "@id": "pl:placementDate",    "@type": "xsd:date" },
    "placementOfficerName":  "pl:placementOfficerName",
    "costDate":              { "@id": "pl:costDate",         "@type": "xsd:date" },
    "costOfficerName":       "pl:costOfficerName"
  }
}
