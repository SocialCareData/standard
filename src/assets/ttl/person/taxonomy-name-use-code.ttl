@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix nuc:   <https://ns.socialcaredata.io/person/name-use-code#> .

<https://ns.socialcaredata.io/person/name-use-code> a owl:Ontology , skos:ConceptScheme ;
    dct:title "Name Use Code Vocabulary" ;
    rdfs:label "Name Use Code" ;
    skos:prefLabel "Name Use Code" ;
    dct:description "Indicates the intended purpose of a person's name. Aligned with the FHIR name-use value set." ;
    owl:versionInfo "1.0.0" ;
    skos:hasTopConcept nuc:Usual , nuc:Official , nuc:Temp , nuc:Nickname , nuc:Anonymous , nuc:Old , nuc:Maiden .

nuc:Usual a skos:Concept ;
    skos:inScheme <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:topConceptOf <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:prefLabel "Usual name" ;
    skos:notation "usual" ;
    skos:definition "The name commonly used by the person — what they normally go by." .

nuc:Official a skos:Concept ;
    skos:inScheme <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:topConceptOf <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:prefLabel "Official name" ;
    skos:notation "official" ;
    skos:definition "The formal name registered in a government register; may not be the name commonly used." .

nuc:Temp a skos:Concept ;
    skos:inScheme <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:topConceptOf <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:prefLabel "Temporary name" ;
    skos:notation "temp" ;
    skos:definition "A temporary name; assigned at birth, in emergencies, or where the person's full name is not yet known." .

nuc:Nickname a skos:Concept ;
    skos:inScheme <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:topConceptOf <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:prefLabel "Nickname" ;
    skos:notation "nickname" ;
    skos:definition "An informal name not part of the person's formal or usual name." .

nuc:Anonymous a skos:Concept ;
    skos:inScheme <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:topConceptOf <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:prefLabel "Anonymous" ;
    skos:notation "anonymous" ;
    skos:definition "A pseudonym used to protect the person's privacy." .

nuc:Old a skos:Concept ;
    skos:inScheme <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:topConceptOf <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:prefLabel "Old name" ;
    skos:notation "old" ;
    skos:definition "A name no longer in use, or never correct, but retained for record-matching purposes." .

nuc:Maiden a skos:Concept ;
    skos:inScheme <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:topConceptOf <https://ns.socialcaredata.io/person/name-use-code> ;
    skos:prefLabel "Maiden name" ;
    skos:notation "maiden" ;
    skos:definition "A name used prior to marriage. Applies regardless of gender." .
