<https://ns.socialcaredata.io/person/person-relationship-code> a owl:Ontology , skos:ConceptScheme ;
    dct:title "Person Relationship Code Vocabulary" ;
    rdfs:label "Person Relationship Code" ;
    skos:prefLabel "Person Relationship Code" ;
    dct:description "Characterises personal relationships between individuals, including family, spousal, foster, adoptive, and other social connections. Aligned with the HL7 v3 PersonalRelationshipRoleType value set." ;
    owl:versionInfo "1.0.0" ;
    skos:hasTopConcept
        prc:FAMMEMB , prc:CHILD , prc:NCHILD , prc:CHLDADOPT , prc:DAUADOPT , prc:SONADOPT ,
        prc:CHLDFOST , prc:DAUFOST , prc:SONFOST , prc:DAUC , prc:DAU , prc:STPDAU ,
        prc:SON , prc:SONC , prc:STPSON , prc:STPCHLD , prc:EXT , prc:AUNT ,
        prc:MAUNT , prc:PAUNT , prc:UNCLE , prc:MUNCLE , prc:PUNCLE , prc:COUSN ,
        prc:MCOUSN , prc:PCOUSN , prc:NIENEPH , prc:NEPHEW , prc:NIECE , prc:GGRPRN ,
        prc:GGRFTH , prc:MGGRFTH , prc:PGGRFTH , prc:GGRMTH , prc:MGGRMTH , prc:PGGRMTH ,
        prc:MGGRPRN , prc:PGGRPRN , prc:GRPRN , prc:GRFTH , prc:MGRFTH , prc:PGRFTH ,
        prc:GRMTH , prc:MGRMTH , prc:PGRMTH , prc:MGRPRN , prc:PGRPRN , prc:GRNDCHILD ,
        prc:GRNDDAU , prc:GRNDSON , prc:INLAW , prc:CHLDINLAW , prc:DAUINLAW , prc:SONINLAW ,
        prc:PRNINLAW , prc:FTHINLAW , prc:MTHINLAW , prc:SIBINLAW , prc:BROINLAW , prc:SISINLAW ,
        prc:PRN , prc:NPRN , prc:ADOPTP , prc:ADOPTF , prc:ADOPTM , prc:PRNFOST ,
        prc:STPPRN , prc:FTH , prc:NFTH , prc:FTHFOST , prc:STPFTH , prc:MTH ,
        prc:NMTH , prc:GESTM , prc:MTHFOST , prc:STPMTH , prc:SIB , prc:NSIB ,
        prc:HSIB , prc:STPSIB , prc:BRO , prc:NBRO , prc:HBRO , prc:STPBRO ,
        prc:SIS , prc:NSIS , prc:HSIS , prc:STPSIS , prc:TWIN , prc:TWINBRO ,
        prc:TWINSIS , prc:ITWIN , prc:ITWINBRO , prc:ITWINSIS , prc:FTWIN , prc:FTWINBRO ,
        prc:FTWINSIS , prc:SPS , prc:HUSB , prc:WIFE , prc:FMRSPS , prc:DOMPART ,
        prc:SIGOTHR , prc:FRND , prc:NBOR , prc:ROOM , prc:ONESELF .

prc:FAMMEMB a skos:Concept ; skos:inScheme <https://ns.socialcaredata.io/person/person-relationship-code> ; skos:topConceptOf <https://ns.socialcaredata.io/person/person-relationship-code> ; skos:prefLabel "Family member" ; skos:notation "FAMMEMB" ; skos:definition "A familial relationship between two people." .
