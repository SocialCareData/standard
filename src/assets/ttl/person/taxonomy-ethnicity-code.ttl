@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ec:    <https://ns.socialcaredata.io/person/ethnicity-code#> .

<https://ns.socialcaredata.io/person/ethnicity-code> a owl:Ontology , skos:ConceptScheme ;
    dct:title "Ethnicity Code Vocabulary" ;
    rdfs:label "Ethnicity Code" ;
    skos:prefLabel "Ethnicity Code" ;
    dct:description "The person's stated ethnicity. Uses ONS Census 2021 Ethnic group classification 20b codes." ;
    owl:versionInfo "1.0.0" ;
    skos:hasTopConcept
        ec:AsianBangladeshi , ec:AsianChinese , ec:AsianIndian , ec:AsianPakistani , ec:AsianOther ,
        ec:BlackAfrican , ec:BlackCaribbean , ec:BlackOther ,
        ec:MixedWhiteAsian , ec:MixedWhiteBlackAfrican , ec:MixedWhiteBlackCaribbean , ec:MixedOther ,
        ec:WhiteBritish , ec:WhiteIrish , ec:WhiteGypsyOrIrishTraveller , ec:WhiteRoma , ec:WhiteOther ,
        ec:OtherArab , ec:OtherAny ,
        ec:DoesNotApply .

ec:AsianBangladeshi a skos:Concept ;
    skos:inScheme <https://ns.socialcaredata.io/person/ethnicity-code> ;
    skos:topConceptOf <https://ns.socialcaredata.io/person/ethnicity-code> ;
    skos:prefLabel "Asian, Asian British or Asian Welsh: Bangladeshi" ;
    skos:notation "1" .

